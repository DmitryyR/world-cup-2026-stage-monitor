generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NEON2_DATABASE_URL")
  directUrl = env("NEON2_DATABASE_URL_UNPOOLED")
}

model Match {
  id         String   @id @default(cuid())
  externalId String   @unique
  stage      String
  homeTeam   String
  awayTeam   String
  homeScore  Int?
  awayScore  Int?
  status     String
  kickoffAt  DateTime
  winner     String?
  rawPayload String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TournamentState {
  id               String   @id @default(cuid())
  currentStage     String
  completedMatches Int
  remainingMatches Int
  champion         String?
  lastCheckedAt    DateTime
  checkerStatus    String
  createdAt        DateTime @default(now())
}

model AgentRun {
  id              String    @id @default(cuid())
  source          String
  status          String
  startedAt       DateTime
  finishedAt      DateTime?
  changesDetected Int
  checkerResult   String
  detectedStage   String?
  errorMessage    String?
}
